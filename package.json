{
  "name": "notesentry",
  "productName": "NoteSentry",
  "version": "0.3.3",
  "description": "本機端 MIMIC-III 臨床紀錄探索助理（資料全程留在本機）",
  "main": "./out/main/index.js",
  "author": "YU-RU, PAN",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/swiftruru/notesentry-mcp.git"
  },
  "scripts": {
    "predev": "node scripts/patch-dev-name.mjs",
    "dev": "electron-vite dev",
    "postinstall": "node scripts/patch-dev-name.mjs",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "package:dir": "electron-vite build && electron-builder --dir",
    "package": "electron-vite build && electron-builder"
  },
  "build": {
    "appId": "tw.edu.ntunhs.ddal.notesentry",
    "productName": "NoteSentry",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "swiftruru",
        "repo": "notesentry-mcp"
      }
    ],
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "mimic_mcp_server.py",
        "to": "mimic_mcp_server.py"
      },
      {
        "from": "clinical_support_mcp_server.py",
        "to": "clinical_support_mcp_server.py"
      },
      {
        "from": "nis_fhir_mcp_server.py",
        "to": "nis_fhir_mcp_server.py"
      },
      {
        "from": "pharmacy_support_mcp_server.py",
        "to": "pharmacy_support_mcp_server.py"
      },
      {
        "from": "build_db.py",
        "to": "build_db.py"
      }
    ],
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.medical",
      "artifactName": "${productName}-mac-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "${productName}-${version}",
      "artifactName": "${productName}-mac-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-win-setup-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-win-portable-${arch}.${ext}"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Science",
      "maintainer": "YU-RU, PAN",
      "artifactName": "${productName}-linux-${arch}.${ext}",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "highlight.js": "^11.11.1",
    "i18next": "^26.3.1",
    "marked": "^14.1.4",
    "ollama": "^0.5.16",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "lucide-react": "^0.468.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "zustand": "^5.0.2"
  }
}
